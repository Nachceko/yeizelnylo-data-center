{
  "name": "yeizel-nylo-data-center",
  "type": "module",
  "version": "1.0.0",
  "description": "YeizelNylo Data Center | YeizelNylo 数据中心",
  "packageManager": "pnpm@11.10.0",
  "author": "Nachceko <2307057760@qq.com>",
  "license": "MIT",
  "scripts": {
    "changelog": "node generate-changelog-git.js",
    "docs:build": "node generate-changelog-git.js && vuepress build docs --clean-cache --clean-temp",
    "docs:dev": "node generate-changelog-git.js && vuepress dev docs",
    "docs:dev-clean": "vuepress dev docs --clean-cache --clean-temp",
    "docs:dev:watch": "nodemon --exec \"node generate-changelog-git.js && vuepress dev docs\" --signal SIGTERM",
    "docs:preview": "http-server docs/.vuepress/dist",
    "vp-update": "pnpm dlx vp-update"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "http-server": "^14.1.1",
    "nodemon": "3.1.14",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vuepress": "2.0.0-rc.30",
    "vuepress-theme-plume": "1.0.0-rc.204"
  },
  "engines": {
    "node": "^20.19.0 || >=22.0.0"
  },
  "dependencies": {
    "ogl": "^1.0.11",
    "repocard": "^1.1.8"
  }
}